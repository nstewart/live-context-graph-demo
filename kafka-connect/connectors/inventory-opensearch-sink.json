{
  "connector.class": "io.aiven.kafka.connect.opensearch.OpensearchSinkConnector",
  "topics": "inventory",
  "connection.url": "http://opensearch:9200",
  "tasks.max": "1",
  "key.converter": "io.confluent.connect.avro.AvroConverter",
  "key.converter.schema.registry.url": "http://redpanda:8081",
  "value.converter": "io.confluent.connect.avro.AvroConverter",
  "value.converter.schema.registry.url": "http://redpanda:8081",
  "key.ignore": "false",
  "schema.ignore": "true",
  "index.write.method": "UPSERT",
  "behavior.on.null.values": "delete",
  "behavior.on.version.conflict": "ignore",
  "transforms": "extractKey,unwrap,cast,tsHeader",
  "transforms.extractKey.type": "org.apache.kafka.connect.transforms.ExtractField$Key",
  "transforms.extractKey.field": "inventory_id",
  "transforms.cast.type": "org.apache.kafka.connect.transforms.Cast$Value",
  "transforms.cast.spec": "base_price:float64,live_price:float64,price_change:float64,zone_adjustment:float64,perishable_adjustment:float64,local_stock_adjustment:float64,popularity_adjustment:float64,scarcity_adjustment:float64,demand_multiplier:float64,demand_premium:float64,basket_adjustment:float64",
  "transforms.unwrap.type": "org.apache.kafka.connect.transforms.ExtractField$Value",
  "transforms.unwrap.field": "after",
  "transforms.tsHeader.type": "io.debezium.transforms.HeaderToValue",
  "transforms.tsHeader.headers": "materialize-timestamp",
  "transforms.tsHeader.fields": "mz_timestamp",
  "transforms.tsHeader.operation": "copy"
}
