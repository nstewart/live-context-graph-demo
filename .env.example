# FreshMart Digital Twin - Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# PostgreSQL (Primary Database)
# =============================================================================
# Local Docker settings (used when PG_EXTERNAL_URL is not set)
PG_HOST=db
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=freshmart

# Optional: External PostgreSQL (e.g., Neon, Supabase, RDS)
# If set, overrides the local Docker settings above
# PG_EXTERNAL_URL=postgresql://user:password@host:5432/database

# =============================================================================
# Materialize Emulator
# =============================================================================
# Local Docker settings
# Admin Console: http://localhost:6874
# SQL Interface: Port 6875
MZ_HOST=mz
MZ_PORT=6875
MZ_CONSOLE_PORT=6874
MZ_USER=materialize
MZ_PASSWORD=materialize
MZ_DATABASE=materialize

# Optional: External Materialize instance
# If set, overrides the local Docker settings above
# MZ_EXTERNAL_URL=postgresql://user:password@host:6875/materialize

# =============================================================================
# OpenSearch
# =============================================================================
OS_HOST=opensearch
OS_PORT=9200
OS_USER=
OS_PASSWORD=
OS_INDEX_ORDERS=orders

# =============================================================================
# API Service
# =============================================================================
API_PORT=8080
LOG_LEVEL=INFO

# =============================================================================
# Web UI
# =============================================================================
WEB_PORT=5173

# =============================================================================
# Search ingest pipeline (Materialize sink -> Redpanda -> Kafka Connect)
# =============================================================================
# Embedding service (OpenAI-compatible facade over fastembed bge-small/384)
EMBEDDING_PORT=8085
EMBEDDING_SERVICE_URL=http://embedding-service:8085
# Redpanda external listener ports (host-facing); internal is redpanda:9092 / :8081
REDPANDA_KAFKA_PORT=19092
REDPANDA_SR_PORT=18081
# Kafka Connect REST API (host-facing)
CONNECT_PORT=8083
# How Materialize reaches Redpanda for the sinks (internal addresses)
REDPANDA_BROKER=redpanda:9092
REDPANDA_SR_URL=http://redpanda:8081

# =============================================================================
# Agent Service
# =============================================================================
AGENT_PORT=8081

# LLM API Keys (at least one required for agent functionality)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
